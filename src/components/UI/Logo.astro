---
interface Props {
  class?: string;
}
const { class: className, ...rest } = Astro.props;
---

<!-- Load Orbitron font -->
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Orbitron:wght@600&display=swap"
/>

<div class={`logo-text ${className || ""}`} {...rest}>
  <span class="api">API</span>
  <span class="astrolab">Astrolab</span>
</div>

<style>
  /* 👇 Fallback colors if global variables are undefined */
  html[data-theme="dark"] {
    --logo-clr-api: #ff4d4f;        /* fallback red dark */
    --logo-clr-astrolab: #e0e0e0;   /* light grey */
  }

  html[data-theme="light"] {
    --logo-clr-api: #d32f2f;        /* fallback red light */
    --logo-clr-astrolab: #111111;   /* almost black */
  }

  .logo-text {
    font-family: 'Orbitron', sans-serif;
    font-size: 2.6rem;
    display: inline-flex;
    gap: 0.4rem;
    align-items: center;
    perspective: 1000px;
    cursor: pointer;
  }

  .api {
    color: var(--logo-clr-api);
    display: inline-block;
    transition: transform 0.5s ease;
    transform-origin: center;
  }

  .astrolab {
    color: var(--logo-clr-astrolab);
    transition: transform 0.3s ease;
  }

  .logo-text:hover .api {
    transform: rotateY(360deg);
  }
</style>
