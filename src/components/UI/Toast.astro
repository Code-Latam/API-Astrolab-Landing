---
import { icons } from "@/assets";

type ResponseData = {
  status: number | string;
  message: string;
}

interface Props {
  active?: boolean;
  id: string;
  responses: Array<ResponseData>;
  variant?: "success" | "error";
}

const { active = false, id, responses, variant } = Astro.props;
---

<div
  id={id}
  class:list={[
    "toast",
    { active },
    variant
  ]}>
  <div class="toast__icon-container">
    <icons.Checkmark class="toast__icon toast__icon--success" />
    <icons.XMark class="toast__icon toast__icon--error" />
  </div>
  <div class="toast__message-container">
    {
      responses.map(({ status, message }) => (
        <p class={`toast__message toast__message--${status}`}>{message}</p>
      ))
    }
  </div>
  <button class="toast__close-button">
    <icons.XMark class="toast__close-button-icon" />
  </button>
  <div class="toast__progress-bar"></div>
</div>

<style>
  .toast {
    position: fixed;
    top: 0;
    right: var(--spacing-horizontal);
    transform: translate(calc(100% + var(--spacing-horizontal)), 200%);
    padding: 1.6rem;
    padding-right: 4.8rem;
    background: var(--clr-white);
    color: var(--clr-grey-graphite);
    z-index: 3;
    box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
    border-radius: var(--border-radius-medium);
    display: flex;
    align-items: center;
    gap: 0.75em;
    overflow: hidden;
    transition: transform 500ms cubic-bezier(0.68, -0.55, 0.265, 1.35);
  }

  html[data-theme="dark"] .toast {
    background: var(--clr-grey-dark);
    color: var(--clr-grey-smoke);
  }

  .active {
    transform: translate(0, 200%);
  }

  .toast__message-container {
    flex: 1;
  }

  .toast__message-container,
  .toast__close-button {
    visibility: hidden;
    opacity: 0;
    transition: visibility 150ms ease-out, opacity 150ms ease-out;
    transition-delay: 150ms;
  }

  .active .toast__message-container,
  .active .toast__close-button {
    opacity: 1;
    visibility: visible;
  }

  .toast__icon,
  .toast__message {
    display: none;
  }

  .toast__icon-container {
    display: flex;
    font-size: 2.4rem;
    color: var(--clr-white);
    padding: 0.25em;
    border-radius: 50%;
  }

  .success .toast__icon-container {
    background-color: var(--clr-green-success);
  }

  .error .toast__icon-container {
    background-color: var(--clr-red-medium);
  }

  .success .toast__icon--success,
  .error .toast__icon--error {
    display: block;
  }

  .success .toast__icon--error,
  .error .toast__icon--success {
    display: none;
  }

  .toast__message {
    display: none;
  }

  .toast__close-button {
    font-size: 0.65em;
    padding: 0.75em;
    display: flex;
    align-items: center;
    border-radius: 50%;
    position: absolute;
    top: 0.5em;
    right: 0.5em;
    color: var(--clr-grey-light);
    background-color: var(--clr-white);
    transition: color 200ms ease-in-out;
  }

  html[data-theme="dark"] .toast__close-button {
    background: var(--clr-grey-dark);
    color: var(--clr-grey-accent);
  }

  .toast__close-button:hover {
    color: var(--clr-grey-dark);
  }

  html[data-theme="dark"] .toast__close-button:hover {
    color: var(--clr-white);
  }

  .toast__close-button-icon {
    pointer-events: none;
  }

  .toast__progress-bar {
    width: 100%;
    height: 0.4rem;
    background-color: var(--clr-white);
    position: absolute;
    bottom: 0;
    left: 0;
  }

  html[data-theme="dark"] .toast__progress-bar {
    background: var(--clr-grey-dark);
  }

  .toast__progress-bar::before {
    content: "";
    position: absolute;
    bottom: 0;
    right: 0;
    height: 100%;
    width: 100%;
  }

  .active .toast__progress-bar:before {
    animation: progress 5s linear forwards;
  }

  .active.success .toast__progress-bar::before {
    background-color: var(--clr-green-success);
  }

  .active.error .toast__progress-bar::before {
    background-color: var(--clr-red-medium);
  }

  @keyframes progress {
    100% {
      right: 100%;
    }
  }
</style>